{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Chat Gateway",
  "version": "2.0.0",
  "identifier": "com.codexchatgateway.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Codex Chat Gateway",
        "width": 1240,
        "height": 820,
        "minWidth": 1020,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "center": true,
        "shadow": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: https://asset.localhost; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:4000 https://github.com https://*.github.com https://objects.githubusercontent.com https://release-assets.githubusercontent.com"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    },
    "publisher": "xuyuanzhang1122",
    "copyright": "MIT",
    "category": "DeveloperTool",
    "shortDescription": "Local model bridge for Codex and Claude Desktop",
    "longDescription": "Codex Chat Gateway Studio — LiteLLM local bridge with Tauri desktop console."
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRBRUJGQjRFOTY0RUIyQzQKUldURXNrNldUdnZyU2h2VDF4T1RxRTQrVW5yL3dhNHBQOGtTcW5KLzZjSHAyNFBRWXZwOUI0cXQK",
      "endpoints": [
        "https://github.com/xuyuanzhang1122/codex-chat-gateway-windows/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
